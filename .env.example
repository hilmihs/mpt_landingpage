# ============================================================
# Muhajir Project Tilawah — Environment Variables Template
# ============================================================
# Copy this to .env.local for dev, and set the same vars in
# Vercel project settings for production.
# Do NOT commit .env.local to git.
# ============================================================

# ---------- Supabase ----------
# Project URL: https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon (public) key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Upstash Redis (BullMQ queue) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- ML Inference Server (Phase 4) ----------
# When set, /api/worker calls real Mu'alim instead of mock-ml
ML_SERVER_URL=
ML_SERVER_API_KEY=

# ---------- Anthropic (AI narrative on rapot) ----------
ANTHROPIC_API_KEY=

# ---------- Zoom Server-to-Server OAuth (Phase 3) ----------
# Create a Server-to-Server OAuth app at https://marketplace.zoom.us
# Required scopes:
#   - meeting:write:meeting:admin
#   - meeting:delete:meeting:admin
#   - user:read:user:admin
#   - meeting:read:past_meeting:admin
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Email of the Zoom Pro user who owns generated meetings (the "Host")
# Pengajar will be added as alternative_host so they can start the meeting
# without being signed in as the host account.
ZOOM_HOST_EMAIL=

# ---------- Zoom Webhook ----------
# After deploying, register webhook URL https://<your-domain>/api/zoom/webhook
# Subscribe to events:
#   - endpoint.url_validation  (Zoom requires this for handshake)
#   - meeting.started
#   - meeting.ended
# Zoom will give you a "Secret Token" — paste it here.
ZOOM_WEBHOOK_SECRET_TOKEN=

# ---------- Site URL (for absolute redirects) ----------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Optional: rate limiting bypass for dev ----------
# Set to "1" to bypass IP rate limiting on /api/submit
DEV_BYPASS_RATELIMIT=
